{
  "name": "@identity-verification/sdk",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./web-components": {
      "import": {
        "types": "./dist/web-components.d.ts",
        "default": "./dist/web-components.js"
      },
      "require": {
        "types": "./dist/web-components.d.cts",
        "default": "./dist/web-components.cjs"
      }
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/web-components.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/web-components.ts --watch --format esm,cjs --dts",
    "test": "vitest run",
    "lint": "eslint .",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "libphonenumber-js": "^1.12.41"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^2.0.0"
  }
}
